# Copy this file to .env and fill in values. Lines starting with # are ignored.

# SAM.gov API (optional — leave empty to skip SAM source)
SAM_API_KEY=

# How far back to search posted dates (1–364; GSA allows max 1 year window)
# SAM_POSTED_LOOKBACK_DAYS=90

# SBIR.gov throttling (429 = too fast)
# SBIR_RATE_LIMIT_MS=4500
# SBIR_INITIAL_DELAY_MS=2500
# SBIR_AGENCY_GAP_MS=6000

# HTTP port for dashboard (optional)
PORT=3000

# SQLite database path (optional — default: data/sniper.db under project root)
# DB_PATH=
