# DSIP Sentinel · ART Edition — environment variables
# Copy to .env and fill in values. .env is gitignored.

# Server
PORT=3000
NODE_ENV=development

# Storage
DB_PATH=./data/dsip-sentinel.db

# Receipt ledger
RECEIPTS_PATH=./receipts.jsonl
MERKLE_BATCH_SIZE=100
MERKLE_ROOT_PATH=./merkle_root.txt

# Auth — HMAC for pre-issued demo tokens (REQUIRED in production)
DEMO_TOKEN_SECRET=8b1127a706ea82958e521299b10eb09e
DEMO_TOKEN_DEFAULT_TTL_DAYS=30

# Auth — magic link (built but dormant in v0.1; Bubba's admin path only)
MAGIC_LINK_SECRET=40d3de06d51f1838352004d99624a245
MAGIC_LINK_TTL_MINUTES=15

# External APIs
SBIR_API_BASE=https://api.www.sbir.gov/public/api/solicitations
SBIR_PAGE_SIZE=25
SBIR_AGENCY_GAP_MS=1500
SBIR_RATE_LIMIT_MS=500
SBIR_INITIAL_DELAY_MS=250
SBIR_429_MAX_RETRIES=8

# SAM.gov — fixture mode is the demo path. Key is optional. See AUDIT_REPORT §8.
SAM_API_KEY=
SAM_USE_FIXTURE=true

# k-anonymity threshold for L1 component aggregation (spec §4)
KANON_MIN_TENANTS=5

# Demo
DEMO_SNAPSHOT_PATH=./data/demo_snapshot.db
